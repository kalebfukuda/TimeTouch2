  <!-- TOPO (3 CARDS) -->
<div class="row mb-3 flex-shrink-0">
  <% if @selected_profile %>
    <div class="col-12 col-md-4 d-flex mb-3 mb-md-0">
      <div class="card flex-fill border-0 rounded-4 custom-card">
        <div class="card-body d-flex flex-column gap-2 p-2">
          <div class="d-flex align-items-center gap-2">
            <div class="icon-box">
              <i class="fa-solid fa-yen-sign"></i>
            </div>
            <div class="label"><%= t("managements.labels.valueWorkedDays") %></div>
          </div>
          <div class="value">¥<%= number_with_delimiter(@total_worked_days) %></div>
          <div class="trend">+ 5% vs mês anterior</div>
        </div>
      </div>
    </div>
    <div class="col-12 col-md-4 d-flex mb-3 mb-md-0">
      <div class="card flex-fill border-0 rounded-4 custom-card">
        <div class="card-body d-flex flex-column gap-2 p-2">
          <div class="d-flex align-items-center gap-2">
            <div class="icon-box">
              <i class="fa-solid fa-yen-sign"></i>
            </div>
            <div class="label"><%= t("managements.labels.extraHours") %></div>
          </div>
          <div class="value">¥<%= number_with_delimiter(@total_extra_hours) %></div>
          <div class="trend">+ 5% vs mês anterior</div>
        </div>
      </div>
    </div>
    <div class="col-12 col-md-4 d-flex mb-3 mb-md-0">
      <div class="card flex-fill border-0 rounded-4 custom-card">
        <div class="card-body d-flex flex-column gap-2 p-2">
          <div class="d-flex align-items-center gap-2">
            <div class="icon-box">
              <i class="fa-solid fa-yen-sign"></i>
            </div>
            <div class="label"><%= t("managements.labels.extraCost") %></div>
          </div>
          <div class="value">¥<%= number_with_delimiter(@total_extra_cost) %></div>
          <div class="trend">+ 5% vs mês anterior</div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="col-12 col-md-4 d-flex mb-3 mb-md-0">
      <div class="card flex-fill border-0 rounded-4 custom-card">
        <div class="card-body d-flex flex-column gap-2 p-2">
          <div class="d-flex align-items-center gap-2">
            <div class="icon-box">
              <i class="fa-solid fa-clock"></i>
            </div>
            <div class="label"><%= t("managements.labels.extraHours") %></div>
          </div>
          <div class="value"><%= @total_extra_hour %>h</div>
          <div class="trend">+ 12% vs mês anterior</div>
        </div>
      </div>
    </div>
    <div class="col-12 col-md-4 d-flex mb-3 mb-md-0">
      <div class="card flex-fill border-0 rounded-4 custom-card">
        <div class="card-body d-flex flex-column gap-2 p-2">
          <div class="d-flex align-items-center gap-2">
            <div class="icon-box">
              <i class="fa-solid fa-yen-sign"></i>
            </div>
            <div class="label"><%= t("managements.labels.totalEarned") %></div>
          </div>
          <div class="value">¥<%= number_with_delimiter(@total_earned) %></div>
          <div class="trend">+ 12% vs mês anterior</div>
        </div>
      </div>
    </div>
    <div class="col-12 col-md-4 d-flex mb-3 mb-md-0">
      <div class="card flex-fill border-0 rounded-4 custom-card">
        <div class="card-body d-flex flex-column gap-2 p-2">
          <div class="d-flex align-items-center gap-2">
            <div class="icon-box">
              <i class="fa-solid fa-helmet-safety"></i>
            </div>
            <div class="label"><%= t("managements.labels.ActiveEmployees") %></div>
          </div>
          <div class="value"><%= @total_active_employees %></div>
          <div class="trend">+ 5% vs mês anterior</div>
        </div>
      </div>
    </div>
  <% end %>
</div>
<!-- CARD GRANDE COM TABELA -->
<div class="flex-fill d-flex dashboard-scroll" style="min-height: 0;max-height: 350px;">
  <div class="card flex-fill border-0 shadow-sm rounded-4" style="min-height: 0;">
    <div class="card-body p-0 d-flex flex-column" style="min-height: 0;">
      <div style="flex: 1; overflow-y: auto; min-height: 0;">
        <table class="table align-middle mb-0 custom-table table-borderless">
          <thead>
            <tr>
              <th><%= t("common.date") %></th>
              <th><%= t("common.gemba") %></th>
              <th><%= t("managements.labels.extraHours") %></th>
              <th><%= t("managements.labels.extraCost") %></th>
              <th class="text-center"><%= t("common.status") %></th>
            </tr>
          </thead>
          <tbody>
            <% @registers.each do |register| %>
              <tr>
                <td><%= register.created_at.strftime("%d/%m/%Y %H:%M") %></td>
                <td><%= register.gemba.name %></td>
                <td><%= register.extra_hour %>h</td>
                <td class="fw-semibold">¥<%= number_with_delimiter(register.extra_cost) %></td>
                <td class="fw-semibold text-center">
                  <% if register.register_status_id == 1 %>
                    <i class="fa-solid fa-calendar-check text-cGreen"></i>
                  <% else %>
                    <i class="fa-solid fa-calendar-xmark text-cRed"></i>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
