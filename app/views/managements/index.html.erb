<div class="container-fluid mt-4 d-flex flex-column">
  <h1 class="mb-3"><%= @name %></h1>
  <div class="row flex-fill" style="min-height: 0;">
    <!-- ESQUERDA -->
    <div class="col-12 col-md-6 mb-3 mb-md-0 d-flex flex-column">
      <div class="flex-fill d-flex dashboard-scroll" style="min-height: 0;">
        <div class="card flex-fill border-0 shadow-sm rounded-4" style="min-height: 0;">
          <div class="card-body p-0 d-flex flex-column" style="min-height: 0;">
            <div style="flex: 1; overflow-y: auto; min-height: 0;">
              <table class="table align-middle mb-0 custom-table table-borderless">
                <thead>
                  <tr>
                    <th>Nome</th>
                    <th>Dias</th>
                    <th>Hora Extra</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th class="text-end">Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% @profiles.each do |profile| %>
                    <tr>
                      <td class="fw-semibold"><%= profile.name %></td>
                      <td><%= profile.total_days %></td>
                      <td><%= profile.total_extra_hours %>h</td>
                      <td class="fw-semibold">¥<%= number_with_delimiter(profile.total_earned) %></td>
                      <td>
                        <% if profile.active %>
                          <span class="badge status-active">Ativo</span>
                        <% else %>
                          <span class="badge status-inactive">Inativo</span>
                        <% end %>
                      </td>
                      <td class="text-end">
                        <%= link_to edit_profile_path(profile), class: "btn btn-sm action-btn" do %>
                          <i class="fa-solid fa-pen"></i>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- DIREITA -->
    <div class="col-12 col-md-6 d-flex flex-column" style="min-height: 0;">
      <!-- TOPO (3 CARDS) -->
      <div class="row mb-3 flex-shrink-0">
        <div class="col-12 col-md-4 d-flex mb-3 mb-md-0">
          <div class="card flex-fill border-0 rounded-4 custom-card">
            <div class="card-body d-flex flex-column gap-2 p-2">
              <div class="d-flex align-items-center gap-2">
                <div class="icon-box">
                  <i class="fa-solid fa-clock"></i>
                </div>
                <div class="label">Horas trabalhadas</div>
              </div>
              <div class="value"><%= @total_days %>h</div>
              <div class="trend">+ 12% vs mês anterior</div>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-4 d-flex mb-3 mb-md-0">
          <div class="card flex-fill border-0 rounded-4 custom-card">
            <div class="card-body d-flex flex-column gap-2 p-2">
              <div class="d-flex align-items-center gap-2">
                <div class="icon-box">
                  <i class="fa-solid fa-yen-sign"></i>
                </div>
                <div class="label">Total a Pagar</div>
              </div>
              <div class="value">¥<%= number_with_delimiter(@total_earned) %></div>
              <div class="trend">+ 12% vs mês anterior</div>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-4 d-flex mb-3 mb-md-0">
          <div class="card flex-fill border-0 rounded-4 custom-card">
            <div class="card-body d-flex flex-column gap-2 p-2">
              <div class="d-flex align-items-center gap-2">
                <div class="icon-box">
                  <i class="fa-solid fa-helmet-safety"></i>
                </div>
                <div class="label">Funcionários Ativos</div>
              </div>
              <div class="value"><%= @total_active_employees %></div>
              <div class="trend">+ 5% vs mês anterior</div>
            </div>
          </div>
        </div>
      </div>
      <!-- CARD GRANDE COM TABELA -->
      <div class="flex-fill d-flex dashboard-scroll" style="min-height: 0;max-height: 350px;">
        <div class="card flex-fill border-0 shadow-sm rounded-4" style="min-height: 0;">
          <div class="card-body p-0 d-flex flex-column" style="min-height: 0;">
            <div style="flex: 1; overflow-y: auto; min-height: 0;">
              <table class="table align-middle mb-0 custom-table table-borderless">
                <thead>
                  <tr>
                    <th>Nome</th>
                    <th>Data</th>
                    <th>Gemba</th>
                    <th>Hora Extra</th>
                    <th>Gasto Extra</th>
                  </tr>
                </thead>
                <tbody>
                  <% @registers.each do |register| %>
                    <tr>
                      <td class="fw-semibold"><%= register.profile_name %></td>
                      <td><%= register.created_at.strftime("%d/%m/%Y %H:%M") %></td>
                      <td><%= register.gemba.name %></td>
                      <td><%= register.extra_hour %>h</td>
                      <td class="fw-semibold">¥<%= number_with_delimiter(register.extra_cost) %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
