<div class="row mb-3 flex-shrink-0">
  <div class="col-12 col-md-4 d-flex mb-3 mb-md-0">
    <div class="card flex-fill border-0 rounded-4 custom-card">
      <div class="card-body d-flex flex-column gap-2 p-3">
        <div class="d-flex align-items-center gap-2">
          <div class="icon-box"><i class="fa-solid fa-clock"></i></div>
          <div class="label">Horas trabalhadas</div>
        </div>
        <div class="value"><%= @total_days %></div>
        <div class="trend">dias no mês</div>
      </div>
    </div>
  </div>
  <div class="col-12 col-md-4 d-flex mb-3 mb-md-0">
    <div class="card flex-fill border-0 rounded-4 custom-card">
      <div class="card-body d-flex flex-column gap-2 p-3">
        <div class="d-flex align-items-center gap-2">
          <div class="icon-box"><i class="fa-solid fa-yen-sign"></i></div>
          <div class="label">Total a Pagar</div>
        </div>
        <div class="value">¥<%= number_with_delimiter(@total_earned) %></div>
        <div class="trend">no mês atual</div>
      </div>
    </div>
  </div>
  <div class="col-12 col-md-4 d-flex">
    <div class="card flex-fill border-0 rounded-4 custom-card">
      <div class="card-body d-flex flex-column gap-2 p-3">
        <div class="d-flex align-items-center gap-2">
          <div class="icon-box"><i class="fa-solid fa-helmet-safety"></i></div>
          <div class="label">Funcionários Ativos</div>
        </div>
        <div class="value"><%= @total_active_employees %></div>
        <div class="trend">de <%= @total_employees %> no total</div>
      </div>
    </div>
  </div>
</div>
