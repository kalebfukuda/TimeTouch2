<div class="px-3 py-4">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="mb-0 fw-semibold" style="font-size: 1.4rem; letter-spacing: -0.02em;">
      Funcionários
    </h1>
    <span class="badge rounded-pill px-3 py-2" style="background: rgba(255,255,255,0.08); font-size: 0.75rem; color: rgba(255,255,255,0.5);">
      <%= Profile.where(company: current_user.profiles.first.company).count %> cadastrados
    </span>
  </div>
  <div class="d-flex flex-column gap-2">
    <% Profile.where(company: current_user.profiles.first.company).each do |profile| %>
      <div class="d-flex align-items-center justify-content-between px-3 py-3 rounded-3"
           id="profile_<%= profile.id %>"
           style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.07); transition: background 0.15s;"
           onmouseover="this.style.background='rgba(255,255,255,0.08)'"
           onmouseout="this.style.background='rgba(255,255,255,0.05)'">
        <%# Nome + status ativo %>
        <div class="d-flex align-items-center gap-3" style="min-width: 0;">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
               style="width: 36px; height: 36px; background: rgba(255,255,255,0.1); font-size: 0.8rem; font-weight: 600; color: rgba(255,255,255,0.7);">
            <%= profile.name.first.upcase %>
          </div>
          <div style="min-width: 0;">
            <a href="<%= edit_profile_path(profile) %>"
               class="text-decoration-none d-block"
               style="color: rgba(255,255,255,0.9); font-size: 0.9rem; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
              <%= profile.name %>
            </a>
            <span style="font-size: 0.72rem; color: rgba(255,255,255,0.35);">
              <% if profile.active %>
                <i class="fa-solid fa-circle" style="font-size: 0.5rem; color: #4ade80;"></i> Ativo
              <% else %>
                <i class="fa-solid fa-circle" style="font-size: 0.5rem; color: #f87171;"></i> Inativo
              <% end %>
            </span>
          </div>
        </div>
        <%# Status LINE %>
        <div class="flex-shrink-0">
          <%= render "profiles/line_status", profile: profile %>
        </div>
      </div>
    <% end %>
  </div>
</div>
